# Copy to .env.local and fill in values:
#   cp .env.example .env.local

# MongoDB — required in production; optional in dev (uses in-memory DB when unset)
# Atlas: Database → Connect → Drivers → copy connection string
# Atlas (Windows): prefer standard URI from Connect → Drivers (mongodb+srv often fails SRV DNS in Node)
MONGODB_URI="mongodb://USER:PASSWORD@host0:27017,host1:27017,host2:27017/apn?ssl=true&authSource=admin&replicaSet=atlas-xxxxx-shard-0"

# Auth — required for login (generate: openssl rand -base64 32)
AUTH_SECRET=replace-with-openssl-rand-base64-32
# Local: http://localhost:3000 — Production: https://your-domain.com
AUTH_URL=http://localhost:3000

# First user with this email becomes admin on register
ADMIN_EMAIL=admin@example.com

NEXT_PUBLIC_SITE_URL=https://www.hinglearn.in
NEXT_PUBLIC_SITE_NAME=HingLearn

# Optional: Google / GitHub OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_ID=
# GITHUB_CLIENT_SECRET=

# Optional: SMTP (password reset emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="HingLearn <noreply@example.com>"

# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
